//@version=6
indicator("EMA 20 / 50 Overlay v2", overlay = true)

source = input.source(close, "Source")
fastLength = input.int(20, "Fast EMA Length", minval = 1)
slowLength = input.int(50, "Slow EMA Length", minval = 1)

fastEma = ta.ema(source, fastLength)
slowEma = ta.ema(source, slowLength)

plot(fastEma, "EMA 20", color=color.teal, linewidth=2)
plot(slowEma, "EMA 50", color=color.orange, linewidth=2)
